# Copie este arquivo para backend/.env e preencha os valores

# URL de conexão com o PostgreSQL
# Exemplo local:  postgresql://postgres:senha@localhost:5432/sucataapp
# Render/Railway: fornecida automaticamente pela plataforma
DATABASE_URL=postgresql://user:password@localhost:5432/sucataapp

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque_por_uma_string_secreta_longa

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# URL pública do app em produção (para restringir CORS)
# Exemplo: https://sucataapp.up.railway.app
ALLOWED_ORIGIN=https://seu-app.up.railway.app
